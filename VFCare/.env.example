# VFCare LangGraph Configuration
# Copy to .env and fill in your values

# LLM Configuration
LLM_PROVIDER=openai                    # openai, anthropic, ollama
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (alternative)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# VFCare Configuration
VEHICLE_ID=VF_LAC_HONG_001
VEHICLE_NAME=VF Lạc Hồng

# Data Paths
DATA_DIR=./data
FEEDBACK_DIR=./data
RULES_FILE=./data/maintenance_rules.json
WORKSHOPS_FILE=./data/workshops.json
VEHICLE_STATUS_FILE=./data/vehicle_status.json
FEEDBACK_FILE=./data/user_feedback.json

# Agent Settings
DEBUG=false
LOG_LEVEL=INFO
MAX_ITERATIONS=10
TIMEOUT=30

# Workshop Configuration
DEFAULT_PRIORITY_WORKSHOP_DISTANCE=10
CRITICAL_TASK_HOURS=1.5
MEDIUM_TASK_HOURS=3
DEFER_DAYS_MEDIUM=5
DEFER_DAYS_LOW=30

# Thresholds (tunable)
CRITICAL_RISK_THRESHOLD=75
MEDIUM_RISK_THRESHOLD=40
LOW_RISK_THRESHOLD=0

# Feature Flags
ENABLE_LLM_REASONING=true
ENABLE_MULTIAGENT=false
ENABLE_FEEDBACK_LEARNING=false
